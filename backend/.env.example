# -----------------------------------------------------------------------------
# Creator Lens - Backend Environment Configuration Template
# Copy this file to '.env' and fill in your actual credentials.
# -----------------------------------------------------------------------------

# --- LLM API Keys ---
# Groq API key is required to run the RAG chat and comparative analysis engine.
# Get your key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# --- Vector Database Settings ---
# Path where Chroma DB will store its serialized collections locally.
CHROMA_DB_PATH=./chroma_data

# --- RAG & Embeddings Configuration ---
# Text embedding model to embed chunks. BAAI/bge-small-en-v1.5 is standard,
# fast, and runs locally using sentence-transformers.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Chunk size and overlap parameters for transcript segment splitting.
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
